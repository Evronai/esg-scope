<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESG Carbon Calculator | Evronai</title>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Source+Sans+3:wght@300;400;500;600;700&family=Source+Code+Pro:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  /* Evronai brand colours */
  --ev-green:  #2DBE6C;
  --ev-teal:     #0F7B5E;
  --ev-lime:  #8DC63F;
  --ev-dark:   #0D1F1A;
  --ev-grey1:   #F2F2F2;
  --ev-grey2:   #E0E0E0;
  --ev-grey3:   #9E9E9E;
  --ev-grey4:   #616161;
  --ev-white:   #FFFFFF;

  /* Scope accent colours — warm, professional */
  --s1:   #0F7B5E;
  --s1l:  rgba(15,123,94,0.09);
  --s2:   #2DBE6C;
  --s2l:  rgba(45,190,108,0.09);
  --s3:   #8DC63F;
  --s3l:  rgba(141,198,63,0.10);

  --ff: 'Source Serif 4', Georgia, serif;
  --fb: 'Source Sans 3', Helvetica, sans-serif;
  --fm: 'Source Code Pro', monospace;
  --r: 2px;
  --rl: 4px;
  --shadow: 0 1px 4px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 4px 24px rgba(0,0,0,0.12), 0 12px 48px rgba(0,0,0,0.08);
}

html { scroll-behavior: smooth; }
body {
  font-family: var(--fb);
  background: var(--ev-grey1);
  color: var(--ev-dark);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ── TOP NAV ── */
.nav {
  background: var(--ev-dark);
  padding: 0 2.5rem;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.ev-mark {
  display: flex;
  align-items: center;
  gap: 3px;
}
.ev-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
}
.ev-dot:nth-child(1) { background: #0F7B5E; }
.ev-dot:nth-child(2) { background: #2DBE6C; }
.ev-dot:nth-child(3) { background: #8DC63F; }
.nav-brand {
  font-family: var(--fb);
  font-weight: 700;
  font-size: 1.1rem;
  color: white;
  letter-spacing: -0.01em;
}
.nav-divider {
  width: 1px; height: 20px;
  background: rgba(255,255,255,0.2);
  margin: 0 1rem;
}
.nav-title {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.55);
  font-weight: 400;
  letter-spacing: 0.02em;
}
.nav-right {
  font-family: var(--fm);
  font-size: 0.65rem;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ── HERO BANNER ── */
.hero {
  background: var(--ev-dark);
  padding: 3rem 2.5rem 3.5rem;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, #0F7B5E 0%, #2DBE6C 50%, #8DC63F 100%);
}
.hero-inner {
  max-width: 1040px;
  margin: 0 auto;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 3rem;
}
.hero-eyebrow {
  font-family: var(--fb);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ev-green);
  margin-bottom: 1rem;
}
.hero h1 {
  font-family: var(--ff);
  font-size: clamp(1.9rem, 3.5vw, 2.8rem);
  font-weight: 300;
  color: white;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.hero h1 strong {
  font-weight: 600;
  color: var(--ev-green);
}
.hero-sub {
  margin-top: 0.9rem;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.55);
  max-width: 480px;
  line-height: 1.7;
  font-weight: 300;
}
.hero-total {
  text-align: right;
  flex-shrink: 0;
}
.ht-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 0.4rem;
}
.ht-number {
  font-family: var(--ff);
  font-size: clamp(3rem, 5vw, 4.5rem);
  font-weight: 300;
  line-height: 1;
  color: var(--ev-green);
  transition: color 0.3s;
}
.ht-unit {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.35);
  font-family: var(--fm);
  margin-top: 0.3rem;
}
.ht-badge {
  display: inline-block;
  margin-top: 0.6rem;
  padding: 0.25rem 0.75rem;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 2px;
  font-size: 0.7rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.04em;
  transition: all 0.3s;
}

/* ── MAIN CONTENT ── */
.content {
  max-width: 1040px;
  margin: 0 auto;
  padding: 2.5rem 2.5rem 5rem;
}

/* ── SCOPE CARDS ── */
.scope-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--ev-grey2);
  border: 1px solid var(--ev-grey2);
  margin-bottom: 2rem;
  box-shadow: var(--shadow);
}
.scope-card {
  background: white;
  padding: 1.5rem 1.75rem;
  position: relative;
  overflow: hidden;
}
.scope-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
}
.scope-card.s1::before { background: var(--s1); }
.scope-card.s2::before { background: var(--s2); }
.scope-card.s3::before { background: var(--s3); }
.sc-eyebrow {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}
.s1 .sc-eyebrow { color: var(--s1); }
.s2 .sc-eyebrow { color: var(--s2); }
.s3 .sc-eyebrow { color: var(--s3); }
.sc-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.25rem; }
.sc-desc { font-size: 0.78rem; color: var(--ev-grey4); line-height: 1.5; }
.sc-total {
  font-family: var(--ff);
  font-size: 1.9rem;
  font-weight: 300;
  line-height: 1;
  margin-top: 1rem;
}
.s1 .sc-total { color: var(--s1); }
.s2 .sc-total { color: var(--s2); }
.s3 .sc-total { color: var(--s3); }
.sc-total-unit { font-family: var(--fm); font-size: 0.6rem; color: var(--ev-grey3); margin-left: 0.25rem; }

/* ── ACCORDION SECTIONS ── */
.acc {
  background: white;
  border: 1px solid var(--ev-grey2);
  margin-bottom: 1px;
  box-shadow: var(--shadow);
  overflow: hidden;
}
.acc:first-of-type { border-radius: var(--rl) var(--rl) 0 0; }
.acc:last-of-type  { border-radius: 0 0 var(--rl) var(--rl); margin-bottom: 2rem; }
.acc-hd {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.75rem;
  cursor: pointer;
  user-select: none;
  border-left: 3px solid transparent;
  transition: background 0.15s, border-color 0.2s;
}
.acc-hd:hover { background: var(--ev-grey1); }
.acc.s1 .acc-hd { border-left-color: var(--s1); }
.acc.s2 .acc-hd { border-left-color: var(--s2); }
.acc.s3 .acc-hd { border-left-color: var(--s3); }
.acc-badge {
  width: 32px; height: 32px;
  border-radius: 2px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--fm); font-size: 0.65rem; font-weight: 500;
  flex-shrink: 0;
  letter-spacing: 0.05em;
}
.s1 .acc-badge { background: var(--s1l); color: var(--s1); }
.s2 .acc-badge { background: var(--s2l); color: var(--s2); }
.s3 .acc-badge { background: var(--s3l); color: var(--s3); }
.acc-meta { flex: 1; }
.acc-meta h2 { font-size: 0.92rem; font-weight: 600; }
.acc-meta p  { font-size: 0.75rem; color: var(--ev-grey3); margin-top: 0.1rem; }
.acc-fig { font-family: var(--ff); font-size: 1.5rem; font-weight: 300; line-height: 1; }
.s1 .acc-fig { color: var(--s1); }
.s2 .acc-fig { color: var(--s2); }
.s3 .acc-fig { color: var(--s3); }
.acc-fig-u { font-family: var(--fm); font-size: 0.58rem; color: var(--ev-grey3); margin-left: 0.2rem; }
.acc-chev {
  width: 24px; height: 24px;
  border: 1px solid var(--ev-grey2);
  border-radius: 2px;
  display: flex; align-items: center; justify-content: center;
  color: var(--ev-grey3); font-size: 0.6rem;
  transition: transform 0.25s, background 0.15s;
  flex-shrink: 0;
}
.acc.open .acc-chev { transform: rotate(180deg); background: var(--ev-grey1); }
.acc-bd { display: none; border-top: 1px solid var(--ev-grey2); }
.acc.open .acc-bd { display: block; }

/* ── INPUT ROWS ── */
.irow {
  display: grid;
  grid-template-columns: 1fr 210px 110px;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem 1.75rem;
  border-bottom: 1px solid var(--ev-grey1);
  transition: background 0.1s;
}
.irow:last-child { border-bottom: none; }
.irow:hover { background: #FAFAFA; }
.rl-name { font-size: 0.875rem; font-weight: 500; color: var(--ev-dark); }
.rl-hint { font-size: 0.72rem; color: var(--ev-grey3); margin-top: 0.1rem; line-height: 1.4; }
.ri {
  display: flex; align-items: center;
  border: 1px solid var(--ev-grey2);
  border-radius: var(--r);
  overflow: hidden;
  background: white;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.ri:focus-within {
  border-color: var(--ev-green);
  box-shadow: 0 0 0 3px rgba(232,119,34,0.12);
}
.ri input {
  flex: 1; background: none; border: none; outline: none;
  padding: 0.55rem 0.8rem;
  font-family: var(--fm); font-size: 0.85rem;
  color: var(--ev-dark); text-align: right;
  width: 100%; min-width: 0;
}
.ri input::placeholder { color: var(--ev-grey3); opacity: 0.6; }
.ru {
  padding: 0.55rem 0.65rem;
  font-family: var(--fm); font-size: 0.62rem;
  color: var(--ev-grey3);
  background: var(--ev-grey1);
  border-left: 1px solid var(--ev-grey2);
  white-space: nowrap;
  line-height: 1;
}
.rr { text-align: right; font-family: var(--fm); font-size: 0.78rem; color: var(--ev-grey3); transition: color 0.2s; }
.rr.on { color: var(--ev-dark); font-weight: 500; }

/* print-only cells */
.p-only { display: none; }

/* ── DISTRIBUTION ── */
.dist {
  background: white;
  border: 1px solid var(--ev-grey2);
  padding: 1.5rem 1.75rem;
  margin-bottom: 2rem;
  box-shadow: var(--shadow);
}
.dist-lbl {
  font-size: 0.62rem; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--ev-grey3); margin-bottom: 0.9rem;
}
.dtrack { height: 6px; background: var(--ev-grey2); border-radius: 1px; display: flex; overflow: hidden; }
.dseg { height: 100%; transition: width 0.6s cubic-bezier(0.4,0,0.2,1); min-width: 0; }
.dseg.s1 { background: var(--s1); }
.dseg.s2 { background: var(--s2); }
.dseg.s3 { background: var(--s3); }
.dleg { display: flex; gap: 2rem; margin-top: 0.9rem; }
.di { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: var(--ev-grey4); }
.ddot { width: 8px; height: 8px; border-radius: 1px; flex-shrink: 0; }
.ddot.s1 { background: var(--s1); } .ddot.s2 { background: var(--s2); } .ddot.s3 { background: var(--s3); }
.dpct { font-family: var(--fm); font-weight: 600; font-size: 0.72rem; }
#pct-s1 { color: var(--s1); } #pct-s2 { color: var(--s2); } #pct-s3 { color: var(--s3); }

/* ── ACTIONS ── */
.acts { display: flex; gap: 0.75rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
.btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  font-family: var(--fb); font-size: 0.84rem; font-weight: 600;
  cursor: pointer; transition: all 0.15s; letter-spacing: 0.01em;
  border: none; border-radius: var(--r);
}
.btn-primary { background: var(--ev-teal); color: white; }
.btn-primary:hover { background: #B83D00; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(208,74,2,0.3); }
.btn-secondary { background: white; color: var(--ev-dark); border: 1px solid var(--ev-grey2); }
.btn-secondary:hover { background: var(--ev-grey1); border-color: var(--ev-grey3); }
.btn-ghost { background: transparent; color: var(--ev-grey4); border: 1px solid var(--ev-grey2); }
.btn-ghost:hover { background: var(--ev-grey1); }
.btn:active { transform: translateY(0) !important; }

/* ── DISCLAIMER ── */
.disc {
  background: white; border: 1px solid var(--ev-grey2);
  border-left: 3px solid var(--ev-green);
  padding: 1.1rem 1.5rem;
  display: flex; gap: 0.9rem; align-items: flex-start;
  font-size: 0.78rem; color: var(--ev-grey4); line-height: 1.6;
}
.disc strong { color: var(--ev-dark); }

/* ── MODAL ── */
.ovl { display: none; position: fixed; inset: 0; background: rgba(29,29,27,0.6); backdrop-filter: blur(4px); z-index: 300; align-items: center; justify-content: center; padding: 1.5rem; }
.ovl.open { display: flex; animation: fi 0.2s ease; }
@keyframes fi { from { opacity: 0; } to { opacity: 1; } }
@keyframes su { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
.modal { background: white; border-radius: var(--rl); max-width: 700px; width: 100%; max-height: 90vh; overflow-y: auto; box-shadow: var(--shadow-lg); animation: su 0.25s ease; }
.mhd {
  padding: 1.75rem 2rem 1.5rem;
  border-bottom: 1px solid var(--ev-grey2);
  display: flex; justify-content: space-between; align-items: flex-start;
  position: sticky; top: 0; background: white; z-index: 1;
  border-top: 4px solid var(--ev-green);
}
.mhd h2 { font-family: var(--ff); font-size: 1.6rem; font-weight: 400; line-height: 1.1; color: var(--ev-dark); }
.mhd h2 span { color: var(--ev-teal); font-weight: 600; }
.mhd p { font-size: 0.75rem; color: var(--ev-grey3); margin-top: 0.3rem; }
.mclose { background: var(--ev-grey1); border: 1px solid var(--ev-grey2); color: var(--ev-grey4); width: 30px; height: 30px; border-radius: 2px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; transition: background 0.15s; flex-shrink: 0; }
.mclose:hover { background: var(--ev-grey2); }
.mbody { padding: 2rem; }
.rblk { margin-bottom: 2rem; }
.rblk:last-child { margin-bottom: 0; }
.rbtl { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ev-grey3); padding-bottom: 0.65rem; border-bottom: 2px solid var(--ev-grey2); margin-bottom: 1rem; }
.sgrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 0.75rem; margin-bottom: 1.25rem; }
.scard { border: 1px solid var(--ev-grey2); padding: 1.1rem 1.25rem; border-radius: var(--r); }
.scard.tot { border-top: 3px solid var(--ev-green); }
.scard.c1  { border-top: 3px solid var(--s1); }
.scard.c2  { border-top: 3px solid var(--s2); }
.scard.c3  { border-top: 3px solid var(--s3); }
.sc-lbl { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ev-grey3); margin-bottom: 0.4rem; }
.sc-val { font-family: var(--ff); font-size: 2rem; font-weight: 300; line-height: 1; }
.scard.tot .sc-val { color: var(--ev-green); }
.scard.c1 .sc-val { color: var(--s1); }
.scard.c2 .sc-val { color: var(--s2); }
.scard.c3 .sc-val { color: var(--s3); }
.sc-unit { font-family: var(--fm); font-size: 0.62rem; color: var(--ev-grey3); margin-top: 0.3rem; }
.rline { display: flex; justify-content: space-between; align-items: baseline; padding: 0.5rem 0; border-bottom: 1px solid var(--ev-grey1); font-size: 0.84rem; }
.rline:last-child { border-bottom: none; }
.rline .rln { color: var(--ev-grey4); }
.rline .rlv { font-family: var(--fm); font-size: 0.76rem; color: var(--ev-dark); font-weight: 500; }
.rec { border-left: 3px solid var(--ev-green); padding: 0.85rem 1rem; margin-bottom: 0.6rem; background: #F2FBF6; border-radius: 0 var(--r) var(--r) 0; }
.rec:last-child { margin-bottom: 0; }
.rec-s { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ev-green); margin-bottom: 0.3rem; }
.rec-t { font-size: 0.84rem; line-height: 1.6; color: var(--ev-dark); }
.mnote { background: var(--ev-grey1); padding: 1rem 1.1rem; font-size: 0.76rem; color: var(--ev-grey4); line-height: 1.7; border-radius: var(--r); }
.mnote strong { color: var(--ev-dark); }

/* ── FOOTER ── */
.footer {
  background: var(--ev-dark);
  padding: 1.5rem 2.5rem;
  display: flex; align-items: center; justify-content: space-between;
}
.footer-left { display: flex; align-items: center; gap: 1rem; }
.footer p { font-size: 0.72rem; color: rgba(255,255,255,0.35); }
.footer strong { color: rgba(255,255,255,0.55); }

/* ── PRINT FOOTER ── */
.p-footer { display: none; }

/* ── ANIMATIONS ── */
.content > * { animation: fu 0.5s ease both; }
.content > *:nth-child(1) { animation-delay: 0.05s; }
.content > *:nth-child(2) { animation-delay: 0.1s; }
.content > *:nth-child(3) { animation-delay: 0.15s; }
.content > *:nth-child(4) { animation-delay: 0.2s; }
@keyframes fu { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--ev-grey1); }
::-webkit-scrollbar-thumb { background: var(--ev-grey2); border-radius: 10px; }

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  .scope-cards { grid-template-columns: 1fr; }
  .hero-inner { flex-direction: column; align-items: flex-start; }
  .hero-total { text-align: left; }
  .ht-badge { float: none; }
  .irow { grid-template-columns: 1fr 160px 95px; gap: 0.75rem; }
  .acts { flex-direction: column; }
  .content { padding: 1.5rem 1.25rem 4rem; }
}

/* =====================================================
   PRINT / PDF STYLES
   ===================================================== */
@media print {
  @page { size: A4; margin: 14mm 16mm 18mm; }

  *, *::before, *::after { box-sizing: border-box; }
  html, body {
    background: #fff !important;
    color: #1D1D1B !important;
    font-size: 10pt;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  .nav, .acts, .disc, .ovl, .footer, .acc-chev { display: none !important; }

  .hero {
    background: #1D1D1B !important;
    padding: 1.2rem 0 1.5rem;
    margin-bottom: 1.2rem;
    page-break-after: avoid;
  }
  .hero::after { height: 3px; }
  .hero-inner { gap: 1.5rem; }
  .hero-eyebrow { font-size: 7pt; }
  .hero h1 { font-size: 20pt; }
  .hero h1 strong { color: #2DBE6C !important; }
  .hero-sub { font-size: 8pt; color: rgba(255,255,255,0.55) !important; }
  .ht-label { font-size: 6pt; }
  .ht-number { font-size: 28pt !important; color: #2DBE6C !important; }
  .ht-unit { font-size: 7pt; }
  .ht-badge { border-color: rgba(255,255,255,0.2) !important; font-size: 7pt; }

  .content { padding: 0; max-width: 100%; }

  .scope-cards { margin-bottom: 1rem; box-shadow: none; gap: 1px; background: #E0E0E0; border-color: #E0E0E0; }
  .scope-card { padding: 0.9rem 1.1rem; background: #fff !important; }
  .scope-card::before { height: 2px !important; }
  .sc-eyebrow { font-size: 6pt; }
  .sc-title { font-size: 8.5pt; }
  .sc-desc { font-size: 7.5pt; }
  .sc-total { font-size: 16pt; margin-top: 0.5rem; }
  .s1 .sc-total { color: #0F7B5E !important; }
  .s2 .sc-total { color: #2DBE6C !important; }
  .s3 .sc-total { color: #8DC63F !important; }
  .sc-total-unit { font-size: 6pt; }

  .acc { border-color: #E0E0E0 !important; margin-bottom: 1px; box-shadow: none; page-break-inside: avoid; }
  .acc:first-of-type, .acc:last-of-type { border-radius: 0; }
  .acc:last-of-type { margin-bottom: 1rem; }
  .acc-hd { padding: 0.7rem 1.1rem; background: #fff !important; }
  .s1 .acc-hd { border-left-color: #0F7B5E !important; }
  .s2 .acc-hd { border-left-color: #2DBE6C !important; }
  .s3 .acc-hd { border-left-color: #8DC63F !important; }
  .s1 .acc-badge { background: rgba(15,123,94,0.09) !important; color: #0F7B5E !important; }
  .s2 .acc-badge { background: rgba(45,190,108,0.09) !important; color: #2DBE6C !important; }
  .s3 .acc-badge { background: rgba(141,198,63,0.10) !important; color: #7ab32e !important; }
  .acc-meta h2 { font-size: 9pt; }
  .acc-meta p  { font-size: 7pt; }
  .acc-fig { font-size: 13pt; }
  .s1 .acc-fig { color: #0F7B5E !important; } .s2 .acc-fig { color: #2DBE6C !important; } .s3 .acc-fig { color: #7ab32e !important; }

  .acc-bd { display: block !important; border-top-color: #E0E0E0 !important; }

  /* Hide inputs; show print cells */
  .ri, .rr { display: none !important; }
  .p-only { display: block !important; }

  .irow {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1.1rem;
    gap: 0;
    border-bottom: 1px solid #F2F2F2 !important;
  }
  .irow:last-child { border-bottom: none !important; }
  .rl-name { font-size: 8pt; color: #1D1D1B !important; }
  .rl-hint { font-size: 6.5pt; color: #9E9E9E !important; }
  .p-entered { font-family: 'Source Code Pro', monospace; font-size: 7.5pt; color: #616161 !important; padding-left: 0.75rem; white-space: nowrap; }
  .p-result  { font-family: 'Source Code Pro', monospace; font-size: 7.5pt; font-weight: 600; padding-left: 0.75rem; white-space: nowrap; min-width: 80px; text-align: right; }
  .p-result.c1 { color: #0F7B5E !important; } .p-result.c2 { color: #2DBE6C !important; } .p-result.c3 { color: #7ab32e !important; }
  .p-result.zero { color: #9E9E9E !important; }

  .dist { border-color: #E0E0E0 !important; padding: 1rem 1.1rem; margin-bottom: 1rem; box-shadow: none; page-break-inside: avoid; }
  .dist-lbl { font-size: 6pt; }
  .dtrack { height: 6px; background: #E0E0E0 !important; }
  .dseg.s1 { background: #0F7B5E !important; } .dseg.s2 { background: #2DBE6C !important; } .dseg.s3 { background: #8DC63F !important; }
  .ddot.s1 { background: #0F7B5E !important; } .ddot.s2 { background: #2DBE6C !important; } .ddot.s3 { background: #8DC63F !important; }
  #pct-s1 { color: #0F7B5E !important; } #pct-s2 { color: #2DBE6C !important; } #pct-s3 { color: #7ab32e !important; }
  .di { font-size: 7.5pt; }

  .p-footer {
    display: block !important;
    margin-top: 1.5rem; padding-top: 0.9rem;
    border-top: 1px solid #E0E0E0;
    font-size: 7pt; color: #9E9E9E !important; line-height: 1.6;
  }
  .p-footer strong { color: #616161 !important; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-logo">
    <div class="ev-mark">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 3C8.477 3 4 7.477 4 13c0 3.5 1.733 6.6 4.4 8.5L14 25l5.6-3.5C22.267 19.6 24 16.5 24 13c0-5.523-4.477-10-10-10z" fill="rgba(45,190,108,0.15)" stroke="#2DBE6C" stroke-width="1.5"/>
        <path d="M10 13c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4" stroke="#2DBE6C" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="14" cy="13" r="1.5" fill="#8DC63F"/>
      </svg>
    </div>
    <span class="nav-brand">Evronai</span>
    <div class="nav-divider"></div>
    <span class="nav-title">ESG Carbon Calculator</span>
  </div>
  <div class="nav-right">GHG Protocol Aligned</div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Sustainability Intelligence Platform</div>
      <h1>ESG Carbon<br><strong>Footprint Calculator</strong></h1>
      <p class="hero-sub">Scope 1, 2 &amp; 3 emissions measurement for small and medium businesses. Aligned with the GHG Protocol Corporate Standard and UK Government conversion factors.</p>
    </div>
    <div class="hero-total">
      <div class="ht-label">Total Annual Footprint</div>
      <div class="ht-number" id="total-big">0.0</div>
      <div class="ht-unit">tCO2e / year</div>
      <div class="ht-badge" id="rating">No data entered</div>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="content">

  <!-- SCOPE SUMMARY CARDS -->
  <div class="scope-cards">
    <div class="scope-card s1">
      <div class="sc-eyebrow">Scope 1</div>
      <div class="sc-title">Direct Emissions</div>
      <div class="sc-desc">Fuel combustion, company vehicles, on-site processes</div>
      <div class="sc-total" id="pill-s1">0.0<span class="sc-total-unit"> tCO2e</span></div>
    </div>
    <div class="scope-card s2">
      <div class="sc-eyebrow">Scope 2</div>
      <div class="sc-title">Purchased Energy</div>
      <div class="sc-desc">Grid electricity, district heating, steam</div>
      <div class="sc-total" id="pill-s2">0.0<span class="sc-total-unit"> tCO2e</span></div>
    </div>
    <div class="scope-card s3">
      <div class="sc-eyebrow">Scope 3</div>
      <div class="sc-title">Value Chain</div>
      <div class="sc-desc">Travel, freight, supply chain, waste, commuting</div>
      <div class="sc-total" id="pill-s3">0.0<span class="sc-total-unit"> tCO2e</span></div>
    </div>
  </div>

  <!-- SCOPE 1 -->
  <div class="acc s1 open" id="sec1">
    <div class="acc-hd" onclick="tog('sec1')">
      <div class="acc-badge">S1</div>
      <div class="acc-meta"><h2>Scope 1 &mdash; Direct Emissions</h2><p>Combustion, fleet, refrigerants</p></div>
      <div class="acc-fig"><span id="fig-s1">0.0</span><span class="acc-fig-u">tCO2e</span></div>
      <div class="acc-chev">&#9662;</div>
    </div>
    <div class="acc-bd">
      <div class="irow" data-id="s1_gas">
        <div><div class="rl-name">Natural Gas</div><div class="rl-hint">Heating, cooking, hot water &mdash; from your gas bill</div></div>
        <div class="ri"><input type="number" id="s1_gas" placeholder="0" min="0" oninput="calc()"><div class="ru">m3 / yr</div></div>
        <div class="rr" id="r_s1_gas">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s1_gas">--</span><span class="p-result c1 zero" id="pr_s1_gas">--</span></div>
      </div>
      <div class="irow" data-id="s1_diesel">
        <div><div class="rl-name">Diesel &mdash; Company Vehicles</div><div class="rl-hint">Litres purchased for owned or leased diesel fleet</div></div>
        <div class="ri"><input type="number" id="s1_diesel" placeholder="0" min="0" oninput="calc()"><div class="ru">litres / yr</div></div>
        <div class="rr" id="r_s1_diesel">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s1_diesel">--</span><span class="p-result c1 zero" id="pr_s1_diesel">--</span></div>
      </div>
      <div class="irow" data-id="s1_petrol">
        <div><div class="rl-name">Petrol &mdash; Company Vehicles</div><div class="rl-hint">Litres purchased for owned or leased petrol fleet</div></div>
        <div class="ri"><input type="number" id="s1_petrol" placeholder="0" min="0" oninput="calc()"><div class="ru">litres / yr</div></div>
        <div class="rr" id="r_s1_petrol">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s1_petrol">--</span><span class="p-result c1 zero" id="pr_s1_petrol">--</span></div>
      </div>
      <div class="irow" data-id="s1_lpg">
        <div><div class="rl-name">LPG / Propane</div><div class="rl-hint">Cooking, heating or industrial processes</div></div>
        <div class="ri"><input type="number" id="s1_lpg" placeholder="0" min="0" oninput="calc()"><div class="ru">litres / yr</div></div>
        <div class="rr" id="r_s1_lpg">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s1_lpg">--</span><span class="p-result c1 zero" id="pr_s1_lpg">--</span></div>
      </div>
      <div class="irow" data-id="s1_refrig">
        <div><div class="rl-name">Refrigerant Top-up (R-410A)</div><div class="rl-hint">Leaked or replaced refrigerant &mdash; AC units, cold storage</div></div>
        <div class="ri"><input type="number" id="s1_refrig" placeholder="0" min="0" oninput="calc()"><div class="ru">kg / yr</div></div>
        <div class="rr" id="r_s1_refrig">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s1_refrig">--</span><span class="p-result c1 zero" id="pr_s1_refrig">--</span></div>
      </div>
    </div>
  </div>

  <!-- SCOPE 2 -->
  <div class="acc s2 open" id="sec2">
    <div class="acc-hd" onclick="tog('sec2')">
      <div class="acc-badge">S2</div>
      <div class="acc-meta"><h2>Scope 2 &mdash; Purchased Energy</h2><p>Grid electricity, district heating, steam</p></div>
      <div class="acc-fig"><span id="fig-s2">0.0</span><span class="acc-fig-u">tCO2e</span></div>
      <div class="acc-chev">&#9662;</div>
    </div>
    <div class="acc-bd">
      <div class="irow" data-id="s2_elec">
        <div><div class="rl-name">Electricity Consumed</div><div class="rl-hint">Total kWh from your electricity bill(s)</div></div>
        <div class="ri"><input type="number" id="s2_elec" placeholder="0" min="0" oninput="calc()"><div class="ru">kWh / yr</div></div>
        <div class="rr" id="r_s2_elec">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s2_elec">--</span><span class="p-result c2 zero" id="pr_s2_elec">--</span></div>
      </div>
      <div class="irow" data-id="s2_renew">
        <div><div class="rl-name">Renewable Offset (solar / REGOs)</div><div class="rl-hint">kWh self-generated or certified renewable &mdash; deducted</div></div>
        <div class="ri"><input type="number" id="s2_renew" placeholder="0" min="0" oninput="calc()"><div class="ru">kWh / yr</div></div>
        <div class="rr" id="r_s2_renew">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s2_renew">--</span><span class="p-result c2 zero" id="pr_s2_renew">--</span></div>
      </div>
      <div class="irow" data-id="s2_heat">
        <div><div class="rl-name">District Heating / Steam</div><div class="rl-hint">Purchased heat from a centralised network</div></div>
        <div class="ri"><input type="number" id="s2_heat" placeholder="0" min="0" oninput="calc()"><div class="ru">kWh / yr</div></div>
        <div class="rr" id="r_s2_heat">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s2_heat">--</span><span class="p-result c2 zero" id="pr_s2_heat">--</span></div>
      </div>
    </div>
  </div>

  <!-- SCOPE 3 -->
  <div class="acc s3 open" id="sec3">
    <div class="acc-hd" onclick="tog('sec3')">
      <div class="acc-badge">S3</div>
      <div class="acc-meta"><h2>Scope 3 &mdash; Value Chain Emissions</h2><p>Travel, freight, waste, supply chain, commuting</p></div>
      <div class="acc-fig"><span id="fig-s3">0.0</span><span class="acc-fig-u">tCO2e</span></div>
      <div class="acc-chev">&#9662;</div>
    </div>
    <div class="acc-bd">
      <div class="irow" data-id="s3_flight_s">
        <div><div class="rl-name">Short-haul Flights</div><div class="rl-hint">Passenger km per year &mdash; under 3,700 km</div></div>
        <div class="ri"><input type="number" id="s3_flight_s" placeholder="0" min="0" oninput="calc()"><div class="ru">pkm / yr</div></div>
        <div class="rr" id="r_s3_flight_s">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_flight_s">--</span><span class="p-result c3 zero" id="pr_s3_flight_s">--</span></div>
      </div>
      <div class="irow" data-id="s3_flight_l">
        <div><div class="rl-name">Long-haul Flights</div><div class="rl-hint">Passenger km per year &mdash; over 3,700 km</div></div>
        <div class="ri"><input type="number" id="s3_flight_l" placeholder="0" min="0" oninput="calc()"><div class="ru">pkm / yr</div></div>
        <div class="rr" id="r_s3_flight_l">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_flight_l">--</span><span class="p-result c3 zero" id="pr_s3_flight_l">--</span></div>
      </div>
      <div class="irow" data-id="s3_commute">
        <div><div class="rl-name">Employee Commuting</div><div class="rl-hint">Total km driven by all staff per year</div></div>
        <div class="ri"><input type="number" id="s3_commute" placeholder="0" min="0" oninput="calc()"><div class="ru">km / yr</div></div>
        <div class="rr" id="r_s3_commute">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_commute">--</span><span class="p-result c3 zero" id="pr_s3_commute">--</span></div>
      </div>
      <div class="irow" data-id="s3_freight">
        <div><div class="rl-name">Road Freight</div><div class="rl-hint">Tonne-km shipped (cargo weight x distance)</div></div>
        <div class="ri"><input type="number" id="s3_freight" placeholder="0" min="0" oninput="calc()"><div class="ru">tkm / yr</div></div>
        <div class="rr" id="r_s3_freight">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_freight">--</span><span class="p-result c3 zero" id="pr_s3_freight">--</span></div>
      </div>
      <div class="irow" data-id="s3_waste">
        <div><div class="rl-name">Waste to Landfill</div><div class="rl-hint">Tonnes of general waste sent to landfill annually</div></div>
        <div class="ri"><input type="number" id="s3_waste" placeholder="0" min="0" oninput="calc()"><div class="ru">t / yr</div></div>
        <div class="rr" id="r_s3_waste">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_waste">--</span><span class="p-result c3 zero" id="pr_s3_waste">--</span></div>
      </div>
      <div class="irow" data-id="s3_hotel">
        <div><div class="rl-name">Hotel Stays</div><div class="rl-hint">Total business accommodation nights across all staff</div></div>
        <div class="ri"><input type="number" id="s3_hotel" placeholder="0" min="0" oninput="calc()"><div class="ru">nights / yr</div></div>
        <div class="rr" id="r_s3_hotel">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_hotel">--</span><span class="p-result c3 zero" id="pr_s3_hotel">--</span></div>
      </div>
      <div class="irow" data-id="s3_goods">
        <div><div class="rl-name">Purchased Goods &amp; Services</div><div class="rl-hint">Annual spend on manufactured goods (spend-based method)</div></div>
        <div class="ri"><input type="number" id="s3_goods" placeholder="0" min="0" oninput="calc()"><div class="ru">GBPk / yr</div></div>
        <div class="rr" id="r_s3_goods">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_goods">--</span><span class="p-result c3 zero" id="pr_s3_goods">--</span></div>
      </div>
      <div class="irow" data-id="s3_water">
        <div><div class="rl-name">Water Consumed</div><div class="rl-hint">m3 supplied and treated &mdash; from water bills</div></div>
        <div class="ri"><input type="number" id="s3_water" placeholder="0" min="0" oninput="calc()"><div class="ru">m3 / yr</div></div>
        <div class="rr" id="r_s3_water">--</div>
        <div class="p-only"><span class="p-entered" id="pe_s3_water">--</span><span class="p-result c3 zero" id="pr_s3_water">--</span></div>
      </div>
    </div>
  </div>

  <!-- DISTRIBUTION -->
  <div class="dist">
    <div class="dist-lbl">Emissions Distribution</div>
    <div class="dtrack">
      <div class="dseg s1" id="bar-s1" style="width:0%"></div>
      <div class="dseg s2" id="bar-s2" style="width:0%"></div>
      <div class="dseg s3" id="bar-s3" style="width:0%"></div>
    </div>
    <div class="dleg">
      <div class="di"><div class="ddot s1"></div><span>Scope 1</span>&nbsp;<span class="dpct" id="pct-s1">0%</span></div>
      <div class="di"><div class="ddot s2"></div><span>Scope 2</span>&nbsp;<span class="dpct" id="pct-s2">0%</span></div>
      <div class="di"><div class="ddot s3"></div><span>Scope 3</span>&nbsp;<span class="dpct" id="pct-s3">0%</span></div>
    </div>
  </div>

  <!-- ACTIONS -->
  <div class="acts">
    <button class="btn btn-primary" onclick="showReport()">View Summary Report</button>
    <button class="btn btn-secondary" onclick="doPrint()">Download PDF</button>
    <button class="btn btn-ghost" onclick="resetAll()">Reset All</button>
  </div>

  <!-- DISCLAIMER -->
  <div class="disc">
    <div>
      <strong>Methodology note:</strong> Results are estimates using <strong>UK Government GHG Conversion Factors (2023)</strong> and <strong>IPCC AR6 GWP values</strong>.
      UK grid electricity factor: 0.233 kgCO2e/kWh. For formal ESG disclosure, CDP submission or CSRD compliance,
      Evronai recommends engaging a certified sustainability consultant and using verified, sector-specific emission factors.
    </div>
  </div>

  <!-- PRINT FOOTER -->
  <div class="p-footer">
    <strong>Evronai Sustainability Intelligence</strong> &nbsp;&middot;&nbsp;
    Emission factors: UK Government GHG Conversion Factors (2023), IPCC AR6 GWP values. UK grid: 0.233 kgCO2e/kWh.
    R-410A GWP: 2,088. Scope 3 spend-based estimates use EXIOBASE sector averages.
    For formal ESG or CSRD reporting, third-party verification is recommended.
    &nbsp;&middot;&nbsp; Generated: <span id="p-date"></span>
  </div>

</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-left">
    <svg width="22" height="22" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M14 3C8.477 3 4 7.477 4 13c0 3.5 1.733 6.6 4.4 8.5L14 25l5.6-3.5C22.267 19.6 24 16.5 24 13c0-5.523-4.477-10-10-10z" fill="rgba(45,190,108,0.2)" stroke="#2DBE6C" stroke-width="1.5"/>
      <path d="M10 13c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4" stroke="#2DBE6C" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="14" cy="13" r="1.5" fill="#8DC63F"/>
    </svg>
    <p><strong>Evronai</strong> &nbsp;&middot;&nbsp; Sustainability Intelligence &nbsp;&middot;&nbsp; ESG Carbon Calculator</p>
  </div>
  <p style="font-size:0.68rem;color:rgba(255,255,255,0.25)">GHG Protocol Corporate Standard Aligned</p>
</footer>

<!-- MODAL -->
<div class="ovl" id="modal">
  <div class="modal">
    <div class="mhd">
      <div><h2>ESG <span>Carbon Report</span></h2><p id="report-meta"></p></div>
      <button class="mclose" onclick="closeModal()">&#x2715;</button>
    </div>
    <div class="mbody" id="modal-body"></div>
  </div>
</div>

<script>
// Emission Factors (kg CO2e per unit)
var EF = {
  s1_gas:2.04, s1_diesel:2.67, s1_petrol:2.31, s1_lpg:1.51, s1_refrig:2088,
  s2_elec:0.233, s2_renew:0.233, s2_heat:0.18,
  s3_flight_s:0.255, s3_flight_l:0.195, s3_commute:0.14, s3_freight:0.062,
  s3_waste:458, s3_hotel:31.2, s3_goods:350, s3_water:0.344
};
var LBL = {
  s1_gas:'Natural Gas', s1_diesel:'Diesel (fleet)', s1_petrol:'Petrol (fleet)',
  s1_lpg:'LPG/Propane', s1_refrig:'Refrigerants',
  s2_elec:'Grid Electricity', s2_renew:'Renewable Offset', s2_heat:'District Heating',
  s3_flight_s:'Short-haul Flights', s3_flight_l:'Long-haul Flights',
  s3_commute:'Employee Commuting', s3_freight:'Road Freight',
  s3_waste:'Landfill Waste', s3_hotel:'Hotel Stays',
  s3_goods:'Purchased Goods', s3_water:'Water'
};
var ULBL = {
  s1_gas:'m3/yr', s1_diesel:'L/yr', s1_petrol:'L/yr', s1_lpg:'L/yr', s1_refrig:'kg/yr',
  s2_elec:'kWh/yr', s2_renew:'kWh/yr', s2_heat:'kWh/yr',
  s3_flight_s:'pkm/yr', s3_flight_l:'pkm/yr', s3_commute:'km/yr', s3_freight:'tkm/yr',
  s3_waste:'t/yr', s3_hotel:'nights/yr', s3_goods:'GBPk/yr', s3_water:'m3/yr'
};

var V = {}, T = {S1:0,S2:0,S3:0,TOTAL:0};

function gv(id) {
  var el = document.getElementById(id);
  return el ? Math.max(0, parseFloat(el.value) || 0) : 0;
}
function fmt(n) { return n >= 100 ? n.toFixed(1) : n.toFixed(2); }
function fmtB(n) { return n >= 1000 ? (n/1000).toFixed(1)+'k' : n >= 100 ? n.toFixed(0) : n.toFixed(1); }

function calc() {
  var keys = Object.keys(EF);
  keys.forEach(function(k) {
    V[k] = gv(k) * EF[k] / 1000;
  });

  keys.forEach(function(k) {
    var el = document.getElementById('r_' + k);
    if (!el) return;
    var val = k === 's2_renew' ? -V[k] : V[k];
    if (Math.abs(val) > 0.0001) {
      el.textContent = (val < 0 ? '-' : '') + fmt(Math.abs(val)) + ' tCO2e';
      el.classList.add('on');
    } else {
      el.textContent = '--';
      el.classList.remove('on');
    }
  });

  var S1 = V.s1_gas + V.s1_diesel + V.s1_petrol + V.s1_lpg + V.s1_refrig;
  var S2 = Math.max(0, V.s2_elec - V.s2_renew + V.s2_heat);
  var S3 = V.s3_flight_s + V.s3_flight_l + V.s3_commute + V.s3_freight +
           V.s3_waste + V.s3_hotel + V.s3_goods + V.s3_water;
  var TOTAL = S1 + S2 + S3;
  T = {S1:S1, S2:S2, S3:S3, TOTAL:TOTAL};

  document.getElementById('fig-s1').textContent = fmt(S1);
  document.getElementById('fig-s2').textContent = fmt(S2);
  document.getElementById('fig-s3').textContent = fmt(S3);
  document.getElementById('pill-s1').innerHTML = fmtB(S1) + '<span class="sc-total-unit"> tCO2e</span>';
  document.getElementById('pill-s2').innerHTML = fmtB(S2) + '<span class="sc-total-unit"> tCO2e</span>';
  document.getElementById('pill-s3').innerHTML = fmtB(S3) + '<span class="sc-total-unit"> tCO2e</span>';
  document.getElementById('total-big').textContent = fmtB(TOTAL);

  var b = document.getElementById('rating');
  if (TOTAL === 0) {
    b.style.borderColor = 'rgba(255,255,255,0.15)'; b.style.color = 'rgba(255,255,255,0.5)'; b.textContent = 'No data entered';
  } else if (TOTAL < 10) {
    b.style.borderColor = '#3ECF8E'; b.style.color = '#3ECF8E'; b.textContent = 'Excellent';
  } else if (TOTAL < 50) {
    b.style.borderColor = '#3ECF8E'; b.style.color = '#3ECF8E'; b.textContent = 'Good';
  } else if (TOTAL < 150) {
    b.style.borderColor = '#FFB600'; b.style.color = '#FFB600'; b.textContent = 'Moderate';
  } else if (TOTAL < 500) {
    b.style.borderColor = '#E87722'; b.style.color = '#E87722'; b.textContent = 'High';
  } else {
    b.style.borderColor = '#D04A02'; b.style.color = '#D04A02'; b.textContent = 'Critical';
  }

  if (TOTAL > 0) {
    ['s1','s2','s3'].forEach(function(s, i) {
      var pct = [S1,S2,S3][i] / TOTAL * 100;
      document.getElementById('bar-' + s).style.width = pct + '%';
      document.getElementById('pct-' + s).textContent = Math.round(pct) + '%';
    });
  } else {
    ['s1','s2','s3'].forEach(function(s) {
      document.getElementById('bar-' + s).style.width = '0%';
      document.getElementById('pct-' + s).textContent = '0%';
    });
  }
}

function tog(id) { document.getElementById(id).classList.toggle('open'); }

function resetAll() {
  document.querySelectorAll('input[type="number"]').forEach(function(i) { i.value = ''; });
  calc();
}

function doPrint() {
  ['sec1','sec2','sec3'].forEach(function(id) { document.getElementById(id).classList.add('open'); });

  Object.keys(EF).forEach(function(k) {
    var raw = gv(k);
    var resEl = document.getElementById('r_' + k);
    var pe = document.getElementById('pe_' + k);
    var pr = document.getElementById('pr_' + k);
    if (!pe || !pr) return;
    pe.textContent = raw > 0 ? (raw.toLocaleString() + ' ' + (ULBL[k] || '')) : '--';
    var resText = resEl ? resEl.textContent : '--';
    pr.textContent = resText;
    var sc = pr.className.match(/c\d/);
    pr.className = 'p-result ' + (sc ? sc[0] : '') + (resText === '--' ? ' zero' : '');
  });

  var pd = document.getElementById('p-date');
  if (pd) pd.textContent = new Date().toLocaleDateString('en-GB', {day:'numeric', month:'long', year:'numeric'});

  setTimeout(function() { window.print(); }, 80);
}

function showReport() {
  var S1 = T.S1, S2 = T.S2, S3 = T.S3, TOTAL = T.TOTAL;
  var date = new Date().toLocaleDateString('en-GB', {year:'numeric', month:'long', day:'numeric'});
  document.getElementById('report-meta').textContent = 'Prepared ' + date;

  var recs = [];
  if (V.s1_gas > 1)                       recs.push({s:'Scope 1 -- Energy',      t:'Transition on-site heating to heat pumps or biomass boilers to eliminate natural gas combustion.'});
  if (V.s1_diesel + V.s1_petrol > 1)      recs.push({s:'Scope 1 -- Fleet',       t:'Transition company vehicles to EVs or hybrids to eliminate direct tailpipe emissions from the fleet.'});
  if (V.s1_refrig > 0.5)                  recs.push({s:'Scope 1 -- Refrigerants',t:'Service AC and refrigeration units regularly to minimise leaks; consider low-GWP refrigerant alternatives.'});
  if (V.s2_elec > 2)                      recs.push({s:'Scope 2 -- Electricity',  t:'Switch to a 100% renewable electricity tariff or install on-site solar with battery storage.'});
  if (V.s3_flight_s + V.s3_flight_l > 1) recs.push({s:'Scope 3 -- Travel',       t:'Implement a travel policy favouring video conferencing; offset unavoidable flights via Gold Standard or VCS.'});
  if (V.s3_commute > 2)                   recs.push({s:'Scope 3 -- Commuting',    t:'Offer hybrid working, subsidised public transport, or a cycle-to-work scheme to reduce commuting emissions.'});
  if (V.s3_waste > 0.5)                   recs.push({s:'Scope 3 -- Waste',        t:'Introduce a waste reduction and recycling programme to divert waste from landfill.'});
  if (V.s3_goods > 2)                     recs.push({s:'Scope 3 -- Supply Chain', t:'Engage key suppliers on decarbonisation targets; request carbon data and prefer lower-carbon alternatives.'});
  if (recs.length === 0) recs.push({s:'General', t:'Your footprint is minimal or data is incomplete. Continue to track annually and engage your supply chain to capture full Scope 3 data.'});

  function rows(keys) {
    var r = keys.filter(function(k) { return V[k] > 0.0001; })
      .map(function(k) { return '<div class="rline"><span class="rln">' + LBL[k] + '</span><span class="rlv">' + fmt(V[k]) + ' tCO2e</span></div>'; })
      .join('');
    return r || '<div class="rline"><span class="rln" style="font-style:italic">No data entered</span><span class="rlv">--</span></div>';
  }

  function pct(n) { return TOTAL > 0 ? Math.round(n / TOTAL * 100) : 0; }

  document.getElementById('modal-body').innerHTML =
    '<div class="rblk"><div class="rbtl">Emissions Overview</div>' +
    '<div class="sgrid">' +
    '<div class="scard tot"><div class="sc-lbl">Total Footprint</div><div class="sc-val">' + fmt(TOTAL) + '</div><div class="sc-unit">tCO2e / year</div></div>' +
    '<div class="scard c1"><div class="sc-lbl">Scope 1 Direct</div><div class="sc-val">' + fmt(S1) + '</div><div class="sc-unit">' + pct(S1) + '% of total</div></div>' +
    '<div class="scard c2"><div class="sc-lbl">Scope 2 Energy</div><div class="sc-val">' + fmt(S2) + '</div><div class="sc-unit">' + pct(S2) + '% of total</div></div>' +
    '<div class="scard c3"><div class="sc-lbl">Scope 3 Value Chain</div><div class="sc-val">' + fmt(S3) + '</div><div class="sc-unit">' + pct(S3) + '% of total</div></div>' +
    '</div></div>' +
    '<div class="rblk"><div class="rbtl">Scope 1 Breakdown</div>' + rows(['s1_gas','s1_diesel','s1_petrol','s1_lpg','s1_refrig']) + '</div>' +
    '<div class="rblk"><div class="rbtl">Scope 2 Breakdown</div>' + rows(['s2_elec','s2_renew','s2_heat']) + '</div>' +
    '<div class="rblk"><div class="rbtl">Scope 3 Breakdown</div>' + rows(['s3_flight_s','s3_flight_l','s3_commute','s3_freight','s3_waste','s3_hotel','s3_goods','s3_water']) + '</div>' +
    '<div class="rblk"><div class="rbtl">Recommended Actions</div>' +
    recs.map(function(r) { return '<div class="rec"><div class="rec-s">' + r.s + '</div><div class="rec-t">' + r.t + '</div></div>'; }).join('') +
    '</div>' +
    '<div class="rblk"><div class="rbtl">Methodology</div>' +
    '<div class="mnote">Emission factors from the <strong>UK Government GHG Conversion Factor repository (2023)</strong> and <strong>IPCC AR6 GWP values</strong>. ' +
    'UK grid: 0.233 kgCO2e/kWh. R-410A GWP: 2,088. Scope 3 spend-based estimates use EXIOBASE averages. ' +
    'For formal ESG disclosure, CDP or CSRD compliance, Evronai recommends third-party verification and sector-specific emission factors.</div></div>';

  document.getElementById('modal').classList.add('open');
}

function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === document.getElementById('modal')) closeModal();
});

calc();
</script>
</body>
</html>
